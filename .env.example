# ============================================================================
# App Identity
# ============================================================================
NEXT_PUBLIC_APP_NAME=my-app
NEXT_PUBLIC_APP_DISPLAY_NAME="My App"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Database — Neon serverless Postgres (or any Postgres in production)
# For local dev use docker-compose (see docker-compose.yml)
# ============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# ============================================================================
# Auth — NextAuth
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
# ============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# Seed (used by prisma/seed.ts only — not needed in production)
# ============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
